{
  "manifest_version": 3,
  "name": "EcomQA — Product Intelligence",
  "version": "1.0.0",
  "description": "Ask anything about Amazon/Flipkart products. BERT-powered Q&A and sentiment analysis without leaving the page.",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": [
    "*://*.amazon.com/*",
    "*://*.amazon.in/*",
    "*://*.amazon.co.uk/*",
    "*://*.amazon.de/*",
    "*://*.amazon.ca/*",
    "*://*.amazon.com.au/*",
    "*://*.flipkart.com/*",
    "https://*.hf.space/*",
    "http://localhost:5000/*",
    "http://127.0.0.1:5000/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.amazon.com/*",
        "*://*.amazon.in/*",
        "*://*.amazon.co.uk/*",
        "*://*.amazon.de/*",
        "*://*.amazon.ca/*",
        "*://*.amazon.com.au/*",
        "*://*.flipkart.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "EcomQA Settings",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["sidebar.html", "sidebar.js", "sidebar.css", "icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
